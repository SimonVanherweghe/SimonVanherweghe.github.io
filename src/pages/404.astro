---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout pageTitle="Page not found">
  <div class="page notfound">
    <p class="notfound__meta">404 — page not found</p>
    <h1 class="notfound__title">This one never got finished.</h1>
    <p class="notfound__body">
      Whatever you were after is somewhere on the pile of failed tests. The
      things that <em>did</em> work out are on
      <a href="/">the homepage</a> — or dig through
      <a href="/archive">the archive</a>.
    </p>
  </div>
</BaseLayout>

<style>
  .notfound {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .notfound__meta {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: var(--space-s);
  }

  .notfound__title {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.03em;
    text-wrap: balance;
    margin-bottom: var(--space-m);
    font-variation-settings: 'opsz' 40;
  }

  .notfound__body {
    font-size: var(--step-0);
    line-height: var(--body-leading);
    max-width: 45ch;
    color: var(--ink-soft);
  }
</style>
