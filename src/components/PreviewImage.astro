---
import { Image } from "astro:assets";

const {
  alt,
  className,
  image,
  priority = false,
  // `width` caps the largest srcset candidate; `sizes` tells the browser which one to pick.
  // Defaults suit a full-bleed image in the 75rem site container.
  width = 1200,
  sizes = "(min-width: 75rem) 75rem, 100vw",
} = Astro.props;
---

<Image
  src={image}
  alt={alt}
  class={className}
  width={width}
  sizes={sizes}
  priority={priority}
/>

<style>
  img {
    display: block;
    width: 100%;
    aspect-ratio: 16/8;
    object-fit: cover;
  }
</style>
